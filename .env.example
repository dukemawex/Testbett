# ---- SAFETY: keep this true until you have reviewed a full dry run ----
DRY_RUN=true

# ---- Staking / risk controls (defaults shown) ----
KELLY_FRACTION=0.25
MAX_STAKE_PCT=0.05
MIN_STAKE=1.0
MAX_BETS_PER_RUN=5
DAILY_LOSS_LIMIT=50.0
MIN_EDGE_THRESHOLD=0.03
INITIAL_BANKROLL=1000.0

# ---- Data / logging ----
LOG_LEVEL=INFO
BANKROLL_FILE=data/bankroll.json
CSV_LOG_FILE=data/runs.csv

# ---- External services (fill with your real keys) ----
ODDS_API_KEY=            # The Odds API key (research/odds)
SEARCH_API_KEY=          # web search provider key (optional research)
OPENAI_API_KEY=          # for the LLM bet analyst
OPENAI_MODEL=gpt-4o-mini

# ---- Live sportsbook (leave BLANK while DRY_RUN=true) ----
SPORTSBOOK_KEY=
SPORTSBOOK_BASE_URL=

# ---- Notifications (optional) ----
SLACK_WEBHOOK_URL=

# ---- Ops ----
GIT_AUTOCOMMIT=false        # if true, bot commits+pushes run logs each run (needs git write creds)

# ---- Real team stats (root-cause fix) ----
FOOTBALL_DATA_API_KEY=      # free key from football-data.org (real goals scored/conceded)
COMPETITION=PL              # PL, PD (La Liga), SA (Serie A), BL1 (Bundesliga), FL1 (Ligue 1)
